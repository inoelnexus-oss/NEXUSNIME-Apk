rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Auth UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - displayName: string (optional) - User display name
    //   - photoURL: string (optional) - User photo URL
    //   - lastNode: string (optional) - Last visited node ID
    //   - createdAt: timestamp (optional) - Account creation timestamp
    //
    // Collection: history
    // Document ID: historyId (Auto-generated)
    // Fields:
    //   - uid: string (required) - User UID
    //   - nodeId: string (required) - Node ID (S1, S2, S3)
    //   - url: string (required) - Visited URL
    //   - timestamp: timestamp (required) - Visit timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() > 0 &&
             data.email.size() < 100;
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['uid', 'nodeId', 'url', 'timestamp']) &&
             data.uid is string &&
             data.nodeId is string &&
             data.url is string &&
             data.url.size() < 2048 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid;
    }

    match /history/{historyId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid &&
                      isValidHistory(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
